# Copy to `.env` for single-user local dev, then set TA_USE_ENV_KEYS=1
# if you want the sidebar to pre-fill the key from here.
# In any multi-user deploy, leave TA_USE_ENV_KEYS unset so each visitor
# enters their own key.

OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional tuning
# TA_USE_ENV_KEYS=1
# TA_VECTOR_ROOT=vector_store
# TA_LLM_RPM=20
# TA_LLM_SESSION_CAP=200
# TA_MAX_FILE_BYTES=209715200        # 200 MB
# TA_MAX_TOTAL_BYTES=209715200       # 200 MB
# TA_LOG_LEVEL=INFO
